<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许局域网 http:// Proxy（CapacitorHttp 原生层 + WebView 双保险） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
